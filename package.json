{
  "name": "booking-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev -H 0.0.0.0",
    "build": "prisma generate && next build",
    "vercel-build": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "tsx --test $(find src -name '*.test.ts' -print)",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:import-clients": "npx tsx scripts/import-rubitime-clients.ts",
    "backup:cli": "npx tsx scripts/backup-cli.ts",
    "db:reset": "prisma migrate reset --force",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.110.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "driver.js": "^1.6.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^6.1.0",
    "shadcn": "^4.11.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
