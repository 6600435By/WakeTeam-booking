generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  timezone       String   @default("Europe/Minsk")
  currency       String   @default("BYN")
  widgetSettings String?
  createdAt      DateTime @default(now())
  branches       Branch[]
  members        OrganizationMember[]
  clients        Client[]
}

model User {
  id                  String               @id @default(cuid())
  login               String               @unique
  email               String?              @unique
  passwordHash        String
  name                String?
  lastName            String?
  phone               String?
  passportNumber      String?
  registrationAddress String?
  createdAt           DateTime             @default(now())
  memberships         OrganizationMember[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("branch_admin")
  branchId       String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  payRates       MemberPayRate[]
  workShifts     WorkShift[]
  spotTasksAssigned SpotTask[] @relation("SpotTaskAssignee")
  spotTasksCreated  SpotTask[] @relation("SpotTaskAssigner")
  shiftChangeRequests ShiftChangeRequest[]
  branchScopes   MemberBranchScope[]
  payrollMonthlyAccruals PayrollMonthlyAccrual[]
  operatorAppointments Appointment[] @relation("AppointmentOperator")
  onboardingCompletedAt DateTime?

  @@unique([organizationId, userId])
}

model MemberBranchScope {
  id       String @id @default(cuid())
  memberId String
  branchId String
  member   OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([memberId, branchId])
  @@index([branchId])
}

model PayrollMonthlyAccrual {
  id                  String   @id @default(cuid())
  organizationId      String
  memberId            String
  periodFrom          String
  periodTo            String
  suggestedAmount     Float
  confirmedAmount     Float?
  comment             String?
  confirmedAt         DateTime?
  confirmedByMemberId String?
  member              OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, periodFrom, periodTo])
  @@index([organizationId, periodFrom, periodTo])
}

model Branch {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  address        String?
  phone          String?
  description    String?
  photoUrl       String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  staff          Staff[]
  services       Service[]
  rentalItems    BranchRentalItem[]
  members        OrganizationMember[]
  memberScopes   MemberBranchScope[]
  weekdaySchedules BranchWeekdaySchedule[]
  holidays       BranchHoliday[]
}

/// weekday: 1 = Monday … 7 = Sunday — часы работы филиала по умолчанию для всех ресурсов
model BranchWeekdaySchedule {
  id        String  @id @default(cuid())
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  weekday   Int
  isWorking Boolean @default(true)
  timeFrom  String
  timeTo    String

  @@unique([branchId, weekday])
}

/// Праздничный день филиала (YYYY-MM-DD, Europe/Minsk)
model BranchHoliday {
  id        String  @id @default(cuid())
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  date      String
  label     String?
  isWorking Boolean @default(true)
  timeFrom  String?
  timeTo    String?
  createdAt DateTime @default(now())

  @@unique([branchId, date])
  @@index([branchId, date])
}

model BranchRentalItem {
  id           String        @id @default(cuid())
  branchId     String
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name         String
  price        Float
  sortOrder    Int           @default(0)
  isActive     Boolean       @default(true)
  appointments Appointment[]
}

model Staff {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  branch         Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name           String
  kind           String    @default("revers")
  description    String?
  photoUrl       String?
  isVisible      Boolean   @default(true)
  isActive       Boolean   @default(true)
  sortOrder      Int       @default(0)
  slotMinutes    Int       @default(10)
  createdAt      DateTime  @default(now())
  schedules      StaffSchedule[]
  scheduleOverrides StaffScheduleOverride[]
  breaks         StaffBreak[]
  services       ServiceStaff[]
  appointments   Appointment[]
  reverseAssignments ReverseAssignment[]
  plannedWorkShifts  WorkShift[] @relation("PlannedReverse")
  shiftPlannedReverses WorkShiftPlannedReverse[] @relation("ShiftPlannedReverses")
}

/// weekday: 1 = Monday … 7 = Sunday
model StaffSchedule {
  id        String  @id @default(cuid())
  staffId   String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  weekday   Int
  isWorking Boolean @default(true)
  timeFrom  String
  timeTo    String

  @@unique([staffId, weekday])
}

/// Исключение из недельного графика на конкретную дату (YYYY-MM-DD, Europe/Minsk)
model StaffScheduleOverride {
  id        String  @id @default(cuid())
  staffId   String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date      String
  isWorking Boolean @default(true)
  timeFrom  String
  timeTo    String

  @@unique([staffId, date])
}

model StaffBreak {
  id       String @id @default(cuid())
  staffId  String
  staff    Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  weekday  Int?
  timeFrom String
  timeTo   String
}

model Service {
  id                String   @id @default(cuid())
  branchId          String
  branch            Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  resourceLabel     String?
  kind              String   @default("wake")
  durationMinutes   Int      @default(10)
  allowedDurations  String   @default("10,30,60")
  price             Float
  bookableFrom      String?
  bookableTo        String?
  weekdays          String   @default("1,2,3,4,5,6,7")
  isActive          Boolean  @default(true)
  isOnlineBookable  Boolean  @default(true)
  sortOrder         Int      @default(0)
  staff             ServiceStaff[]
  appointments      Appointment[]
  priceRules        ServicePriceRule[]
}

model ServicePriceRule {
  id                String  @id @default(cuid())
  serviceId         String
  service           Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  weekdays          String
  timeFrom          String
  timeTo            String
  price             Float
  pricesByDuration  String?
  sortOrder         Int     @default(0)
}

model ServiceStaff {
  serviceId String
  staffId   String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@id([serviceId, staffId])
}

model Client {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  firstName      String?
  lastName       String?
  phone          String
  email          String?
  notes          String?
  createdAt      DateTime @default(now())
  appointments   Appointment[]

  @@unique([organizationId, phone])
}

model Appointment {
  id              String   @id @default(cuid())
  publicNumber    Int?     @unique
  organizationId  String
  branchId        String
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  staffId         String
  staff           Staff    @relation(fields: [staffId], references: [id])
  serviceId       String
  service         Service  @relation(fields: [serviceId], references: [id])
  startAt         DateTime
  endAt           DateTime
  durationMinutes Int
  price           Float
  paymentMethod   String?
  status          String   @default("booked")
  cancelReason    String?
  source          String   @default("widget")
  comment         String?
  bookingGroupId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  membershipId              String?
  membership                Membership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  membershipMinutesDeducted Int         @default(0)
  rentalItemId              String?
  rentalItem                BranchRentalItem? @relation(fields: [rentalItemId], references: [id], onDelete: SetNull)
  rentalQuantity            Int         @default(0)
  rentalAmount              Float       @default(0)
  operatorMemberId          String?
  operatorMember            OrganizationMember? @relation("AppointmentOperator", fields: [operatorMemberId], references: [id], onDelete: SetNull)

  @@index([staffId, startAt])
  @@index([startAt])
  @@index([organizationId, startAt])
  @@index([organizationId, branchId, startAt])
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Membership {
  id                    String   @id @default(cuid())
  organizationId        String
  externalCode          String
  category              String?
  ownerName             String?
  phone                 String
  saleDate              DateTime?
  initialMinutes        Int      @default(0)
  pricePerMinute        Float?
  sheetRemainingMinutes Int      @default(0)
  localDeductedMinutes  Int      @default(0)
  comment               String?
  syncedAt              DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  appointments          Appointment[]
  transactions          MembershipTransaction[]

  @@unique([organizationId, externalCode])
  @@index([organizationId, phone])
}

model MembershipTransaction {
  id            String     @id @default(cuid())
  membershipId  String
  membership    Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  appointmentId String?
  minutes       Int
  reason        String
  createdAt     DateTime   @default(now())

  @@index([membershipId])
  @@index([appointmentId])
}

/// panel | spot | idle | shift
model MemberPayRate {
  id                String             @id @default(cuid())
  memberId          String
  member            OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  kind              String
  amount            Float
  effectiveFrom     String
  effectiveTo       String?
  createdAt         DateTime           @default(now())
  createdByMemberId String?

  @@index([memberId, kind, effectiveFrom])
}

model WorkShift {
  id                   String             @id @default(cuid())
  organizationId       String
  branchId             String
  memberId             String
  member               OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  date                 String
  plannedStart         String?
  plannedEnd           String?
  actualStart          DateTime?
  actualEnd            DateTime?
  status               String             @default("open")
  panelMinutesOverride Int?
  idleMinutesOverride  Int?
  ratesSnapshot        String?
  plannedStaffId       String?
  plannedStaff         Staff?             @relation("PlannedReverse", fields: [plannedStaffId], references: [id], onDelete: SetNull)
  workAsAdmin            Boolean            @default(false)
  employeeSubmittedAt    DateTime?
  employeeSubmitComment  String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  reverseAssignments     ReverseAssignment[]
  spotEntries            SpotWorkEntry[]
  adjustments            ShiftAdjustment[]
  changeRequests         ShiftChangeRequest[]
  baselineCompletions    ShiftBaselineCompletion[]
  checklistCompletions   ShiftChecklistCompletion[]
  handoffNotes           ShiftHandoffNote[]
  plannedReverses        WorkShiftPlannedReverse[]

  @@unique([memberId, date])
  @@index([branchId, date, status])
}

model ReverseAssignment {
  id        String    @id @default(cuid())
  shiftId   String
  shift     WorkShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  staffId   String
  staff     Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startedAt DateTime
  endedAt   DateTime?

  @@index([shiftId])
}

model WorkShiftPlannedReverse {
  id       String    @id @default(cuid())
  shiftId  String
  shift    WorkShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  staffId  String
  staff    Staff     @relation("ShiftPlannedReverses", fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([shiftId, staffId])
  @@index([shiftId])
  @@index([staffId])
}

model SpotWorkEntry {
  id                String    @id @default(cuid())
  shiftId           String
  shift             WorkShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  taskId            String?
  task              SpotTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  category          String?
  comment           String
  startedAt         DateTime
  endedAt           DateTime?
  source            String    @default("manual")
  isActive          Boolean   @default(false)
  confirmedAt       DateTime?
  confirmedById     String?
  createdByMemberId String

  @@index([shiftId])
}

model BranchShiftChecklistItem {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String
  label          String
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  completions    ShiftChecklistCompletion[]

  @@index([branchId, isActive, sortOrder])
}

model ShiftChecklistCompletion {
  id          String                   @id @default(cuid())
  itemId      String
  item        BranchShiftChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  workShiftId String
  workShift   WorkShift                @relation(fields: [workShiftId], references: [id], onDelete: Cascade)
  memberId    String
  completedAt DateTime                 @default(now())

  @@unique([itemId, workShiftId])
  @@index([workShiftId])
}

model SpotTask {
  id                 String             @id @default(cuid())
  organizationId     String
  branchId           String
  assigneeMemberId   String
  assignee           OrganizationMember @relation("SpotTaskAssignee", fields: [assigneeMemberId], references: [id], onDelete: Cascade)
  assignedByMemberId String
  assignedBy         OrganizationMember @relation("SpotTaskAssigner", fields: [assignedByMemberId], references: [id], onDelete: Cascade)
  date               String
  description        String
  category           String?
  plannedMinutes     Int?
  plannedTimeFrom    String?
  plannedTimeTo      String?
  status             String             @default("pending")
  spotEntryId        String?
  branchWide         Boolean            @default(false)
  groupId            String?
  totalPlannedMinutes Int?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  spotEntries        SpotWorkEntry[]

  @@index([assigneeMemberId, date])
  @@index([branchId, date, status])
  @@index([groupId])
}

model ShiftBaselineTask {
  id                 String   @id @default(cuid())
  organizationId     String
  branchId           String
  date               String
  description        String
  sortOrder          Int      @default(0)
  assignedByMemberId String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  completions        ShiftBaselineCompletion[]

  @@index([branchId, date])
}

model ShiftBaselineCompletion {
  id          String            @id @default(cuid())
  taskId      String
  task        ShiftBaselineTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workShiftId String
  workShift   WorkShift         @relation(fields: [workShiftId], references: [id], onDelete: Cascade)
  memberId    String
  completedAt DateTime          @default(now())

  @@unique([taskId, workShiftId])
  @@index([workShiftId])
}

model ShiftHandoffNote {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  targetDate     String
  workShiftId    String
  workShift      WorkShift @relation(fields: [workShiftId], references: [id], onDelete: Cascade)
  memberId       String
  comment        String
  createdAt      DateTime  @default(now())

  @@unique([workShiftId, targetDate])
  @@index([branchId, targetDate])
}

model ShiftAdjustment {
  id                String    @id @default(cuid())
  shiftId           String
  shift             WorkShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  field             String
  oldValue          String
  newValue          String
  comment           String
  createdByMemberId String
  createdAt         DateTime  @default(now())

  @@index([shiftId])
}

model ShiftChangeRequest {
  id                 String             @id @default(cuid())
  organizationId     String
  branchId           String
  memberId           String
  member             OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  workShiftId        String?
  workShift          WorkShift?         @relation(fields: [workShiftId], references: [id], onDelete: SetNull)
  date               String
  requestType        String
  message            String
  proposedStart      String?
  proposedEnd        String?
  proposedStaffId    String?
  status             String             @default("pending")
  reviewComment      String?
  reviewedByMemberId String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([memberId, status])
  @@index([branchId, status, date])
}

model AdminActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  createdAt      DateTime @default(now())
  action         String
  actorMemberId  String?
  actorName      String   @db.VarChar(80)
  branchId       String?
  entityType     String?
  entityId       String?
  summary        String   @db.VarChar(280)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, action, createdAt(sort: Desc)])
  @@index([createdAt])
}

