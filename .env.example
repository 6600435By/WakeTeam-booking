# PostgreSQL connection string (pick one):

# Homebrew Postgres on macOS (user = your Mac username, no password):
# DATABASE_URL="postgresql://YOUR_MAC_USER@localhost:5432/booking_crm?schema=public"

# Docker / Linux:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/booking_crm?schema=public"

# Neon / Supabase (production & cloud dev):
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/booking_crm?schema=public"

ADMIN_EMAIL="admin@waketeam.by"
ADMIN_PASSWORD="changeme"
BRANCH_ADMIN_PASSWORD="changeme"

# Admin session TTL (ms). Default: 14 days.
# SESSION_TTL_MS=1209600000

# Rate limits (per client IP, in-memory — single-instance deployments).
# RATE_LIMIT_LOGIN_MAX=10
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_PUBLIC_WRITE_MAX=15
# RATE_LIMIT_PUBLIC_WRITE_WINDOW_MS=900000
# RATE_LIMIT_PUBLIC_READ_MAX=120
# RATE_LIMIT_PUBLIC_READ_WINDOW_MS=60000

# Supabase Storage (required in production on Vercel; optional locally — falls back to public/uploads/)
# SUPABASE_URL="https://xxx.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Backups (Supabase bucket "backups" + GitHub Actions; restore from admin needs Vercel vars below)
# BACKUP_RESTORE_SECRET="random-string-for-restore-hmac"
# GITHUB_BACKUP_TOKEN="ghp_..."
# GITHUB_REPO="owner/booking-crm"
# BACKUP_SEASON_START_MONTH=5
# BACKUP_SEASON_END_MONTH=10

MEMBERSHIPS_SHEET_URL="https://docs.google.com/spreadsheets/d/e/.../pubhtml"
MEMBERSHIPS_SYNC_INTERVAL_MIN=15
